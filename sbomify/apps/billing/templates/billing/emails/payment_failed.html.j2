{% extends "core/emails/base.html.j2" %}
{% block title %}Payment Failed{% endblock %}
{% block content %}
    <h1>Payment failed</h1>
    <p>Hi {{ user_name }},</p>
    <p>
        We were unable to process your payment for workspace "{{ team_name }}".
        We'll automatically retry, but please update your payment information
        to avoid any service interruption.
    </p>
    <p style="text-align: center; margin: 32px 0;">
        <a href="{{ action_url }}" class="button">Update Payment Information</a>
    </p>
{% endblock %}
