{% extends "core/emails/base.html.j2" %}
{% block title %}Payment Past Due{% endblock %}
{% block content %}
    <h1>Payment past due</h1>
    <p>Hi {{ user_name }},</p>
    <p>
        Your subscription payment for workspace "{{ team_name }}" is past due.
        Please update your payment information to avoid any service interruption.
    </p>
    <p style="text-align: center; margin: 32px 0;">
        <a href="{{ action_url }}" class="button">Update Payment Information</a>
    </p>
{% endblock %}
