{% extends "core/emails/base.html.j2" %}
{% block title %}Subscription Cancelled{% endblock %}
{% block content %}
    <h1>Subscription cancelled</h1>
    <p>Hi {{ user_name }},</p>
    <p>
        Your subscription for workspace "{{ team_name }}" has been cancelled.
        Your workspace will revert to the community plan with limited features.
    </p>
    <p>Changed your mind? You can reactivate any time:</p>
    <p style="text-align: center; margin: 32px 0;">
        <a href="{{ action_url }}" class="button">Reactivate Subscription</a>
    </p>
{% endblock %}
