{% extends "core/emails/base.html.j2" %}
{% block title %}Subscription Ended{% endblock %}
{% block content %}
    <h1>Subscription ended</h1>
    <p>Hi {{ user_name }},</p>
    <p>
        Your subscription for {{ team_name }} has ended and access to premium features
        has been deactivated. You can renew any time to pick up where you left off.
    </p>
    <p style="text-align: center; margin: 32px 0;">
        <a href="{{ upgrade_url }}" class="button">Renew Subscription</a>
    </p>
{% endblock %}
