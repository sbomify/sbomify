{% extends "core/emails/base.html.j2" %}
{% block title %}Trial Period Expired{% endblock %}
{% block content %}
    <h1>Your trial has ended</h1>
    <p>Hi {{ user_name }},</p>
    <p>
        Your trial for <strong>{{ team_name }}</strong> has ended. Upgrade to a paid plan
        to continue using all features.
    </p>
    <p style="text-align: center; margin: 32px 0;">
        <a href="{{ upgrade_url }}" class="button">Upgrade Now</a>
    </p>
{% endblock %}
