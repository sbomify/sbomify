{% comment %}
    Finding status toggle — 3 buttons: Satisfied / Not Satisfied / N/A.
    Visual state is driven by `buttonState(finding)` so the `_pendingNA`
    rule lives in exactly one place; do not re-derive it in this template.
    Used inside an x-for loop with `finding` variable in scope.
{% endcomment %}
<div class="inline-flex shrink-0">
    <button type="button"
            @click="setFindingStatus(finding, 'satisfied')"
            :class="buttonState(finding) === 'satisfied' ? 'bg-green-600 text-white border-green-600' : 'bg-surface text-text-muted border-border hover:bg-green-50 hover:text-green-600 dark:hover:bg-green-900/10'"
            class="px-2.5 py-1 text-xs font-medium rounded-l-md border transition-colors focus:outline-none whitespace-nowrap">
        <i class="fas fa-check mr-0.5"></i> Satisfied
    </button>
    <button type="button"
            @click="setFindingStatus(finding, 'not-satisfied')"
            :class="buttonState(finding) === 'not-satisfied' ? 'bg-red-600 text-white border-red-600' : 'bg-surface text-text-muted border-border hover:bg-red-50 hover:text-red-600 dark:hover:bg-red-900/10'"
            class="-ml-px px-2.5 py-1 text-xs font-medium border transition-colors focus:outline-none whitespace-nowrap">
        <i class="fas fa-times mr-0.5"></i> Not Satisfied
    </button>
    <button type="button"
            @click="setFindingStatus(finding, 'not-applicable')"
            :disabled="finding.is_mandatory"
            :class="buttonState(finding) === 'not-applicable' ? 'bg-text text-surface border-text' : buttonState(finding) === 'pending-na' ? 'bg-amber-100 text-amber-900 border-amber-400 dark:bg-amber-900/40 dark:text-amber-100 dark:border-amber-500' : finding.is_mandatory ? 'bg-surface text-text-muted/30 border-border cursor-not-allowed' : 'bg-surface text-text-muted border-border hover:bg-surface-hover hover:text-text dark:hover:bg-gray-800/50'"
            class="-ml-px px-2.5 py-1 text-xs font-medium rounded-r-md border transition-colors focus:outline-none whitespace-nowrap"
            :title="finding.is_mandatory ? 'Part II controls are always mandatory (CRA Art 13(4))' : buttonState(finding) === 'pending-na' ? 'Awaiting justification — provide one to commit N/A' : 'Mark as not applicable'">
        N/A
    </button>
</div>
