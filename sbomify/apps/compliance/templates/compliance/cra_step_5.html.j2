{% extends "compliance/cra_wizard_base.html.j2" %}
{% block step_wrapper %}
    <div x-data="craStep5()">
        {{ step_data_json|json_script:"step-data" }}
        {{ assessment_meta|json_script:"assessment-meta" }}
        {{ step_urls|json_script:"step-urls" }}
        {# Step content #}
        <div class="space-y-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                {# Left: Summary #}
                <div class="space-y-6">
                    <div class="tw-card">
                        <div class="px-6 py-4 border-b border-border">
                            <h2 class="text-lg font-semibold text-text flex items-center gap-2 m-0">
                                <i class="fas fa-chart-pie text-primary"></i>
                                Compliance Summary
                            </h2>
                            <p class="text-sm text-text-muted mt-1">Overall CRA compliance posture across all assessment steps</p>
                        </div>
                        <div class="p-6">
                            <div class="flex items-center gap-6 mb-6">
                                {# Compliance percentage with colored ring #}
                                <div class="text-center shrink-0">
                                    <div class="relative inline-flex items-center justify-center w-24 h-24">
                                        {# Background ring #}
                                        <svg class="w-24 h-24 -rotate-90" viewBox="0 0 96 96">
                                            <circle cx="48" cy="48" r="40" fill="none" stroke="currentColor" class="text-border" stroke-width="8" />
                                            <circle cx="48" cy="48" r="40" fill="none" stroke="currentColor" :class="compliancePercent >= 80 ? 'text-green-500' : compliancePercent >= 50 ? 'text-amber-500' : 'text-red-500'" stroke-width="8" stroke-linecap="round" :stroke-dasharray="2 * Math.PI * 40" :stroke-dashoffset="2 * Math.PI * 40 * (1 - compliancePercent / 100)" />
                                        </svg>
                                        <span class="absolute text-2xl font-bold"
                                              :class="compliancePercent >= 80 ? 'text-green-600' : compliancePercent >= 50 ? 'text-amber-600' : 'text-red-600'"
                                              x-text="compliancePercent + '%'"></span>
                                    </div>
                                    <span class="block text-xs text-text-muted mt-1">Controls Satisfied</span>
                                </div>
                                <div class="flex-1 text-sm text-text-muted space-y-1">
                                    <p>
                                        <span class="font-medium text-text" x-text="satisfiedCount"></span> / <span x-text="totalControls"></span> controls satisfied
                                    </p>
                                    <p x-show="controlsSummary['not-satisfied']">
                                        <span class="text-red-600 font-medium"
                                              x-text="controlsSummary['not-satisfied']"></span> not satisfied
                                    </p>
                                    <p x-show="controlsSummary['unanswered']">
                                        <span class="text-amber-600 font-medium"
                                              x-text="controlsSummary['unanswered']"></span> unanswered
                                    </p>
                                </div>
                            </div>
                            {# Progress bar #}
                            <div class="mb-6">
                                <div class="flex justify-between text-xs text-text-muted mb-1">
                                    <span>Progress</span>
                                    <span x-text="satisfiedCount + ' / ' + totalControls"></span>
                                </div>
                                <div class="w-full h-2.5 bg-surface-hover rounded-full overflow-hidden">
                                    <div class="h-full rounded-full transition-all duration-500"
                                         :class="compliancePercent >= 80 ? 'bg-green-500' : compliancePercent >= 50 ? 'bg-amber-500' : 'bg-red-500'"
                                         :style="'width: ' + compliancePercent + '%'"></div>
                                </div>
                            </div>
                            {# Step completion list with names #}
                            <div class="space-y-2">
                                <template x-for="s in [ {num: 1, name: 'Product Classification'}, {num: 2, name: 'SBOM & Components'}, {num: 3, name: 'Security Requirements'}, {num: 4, name: 'User Information'} ]"
                                          :key="s.num">
                                    <div class="flex items-center gap-2 text-sm">
                                        <i class="fas text-xs"
                                           :class="steps[s.num]?.complete ? 'fa-check-circle text-green-600' : 'fa-circle text-text-muted'"></i>
                                        <span class="text-text">
                                            <span class="text-text-muted" x-text="'Step ' + s.num + ':'"></span>
                                            <span x-text="s.name"></span>
                                        </span>
                                        <template x-if="!steps[s.num]?.complete">
                                            <a :href="stepUrls[s.num] || '#'"
                                               class="text-primary text-xs hover:underline ml-auto">Go to step</a>
                                        </template>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </div>
                    {% comment %}
                    Manufacturer signature pad. Captures the Annex V signature
                    block (place / name / function / drawn signature) so the
                    generated DoC fills in those fields instead of underscore
                    placeholders. Saving marks the existing DoC stale; the
                    operator must regenerate to publish the new signature.
                    {% endcomment %}
                    <div class="tw-card" x-data="craDocSignature()" x-init="init()">
                        <div class="px-6 py-4 border-b border-border">
                            <h2 class="text-lg font-semibold text-text flex items-center gap-2 m-0">
                                <i class="fas fa-signature text-primary"></i>
                                Sign the Declaration of Conformity
                            </h2>
                            <p class="text-sm text-text-muted mt-1">
                                CRA Annex V Section 8 — captured once and embedded in the rendered DoC. Saving marks the DoC stale; click <em>Generate Declaration of Conformity</em> below to refresh it.
                            </p>
                        </div>
                        <div class="p-6 space-y-4">
                            <div class="space-y-4">
                                <div class="grid gap-4 md:grid-cols-3">
                                    <label class="text-sm">
                                        <span class="block mb-1 text-text font-medium">Place <span class="text-error">*</span></span>
                                        <input type="text"
                                               x-model="place"
                                               maxlength="255"
                                               placeholder="City, country"
                                               class="tw-form-input w-full">
                                    </label>
                                    <label class="text-sm">
                                        <span class="block mb-1 text-text font-medium">Name <span class="text-error">*</span></span>
                                        <input type="text"
                                               x-model="name"
                                               maxlength="255"
                                               placeholder="Full legal name"
                                               class="tw-form-input w-full">
                                    </label>
                                    <label class="text-sm">
                                        <span class="block mb-1 text-text font-medium">Function <span class="text-error">*</span></span>
                                        <input type="text"
                                               x-model="roleFunction"
                                               maxlength="255"
                                               placeholder="Role / title"
                                               class="tw-form-input w-full">
                                    </label>
                                </div>
                                <div>
                                    <span class="block mb-1 text-sm text-text font-medium">Signature <span class="text-error">*</span></span>
                                    <div class="border border-border rounded-lg bg-white"
                                         style="height: 160px">
                                        <canvas x-ref="canvas"
                                                aria-label="Signature pad — draw your signature with mouse or touch"
                                                class="w-full h-full block touch-none"></canvas>
                                    </div>
                                    <p class="text-xs text-text-muted mt-1 m-0">
                                        Drawn signature is captured as a PNG and embedded in the DoC. This is a digitally captured signature, not an eIDAS-qualified electronic signature.
                                    </p>
                                </div>
                                <div class="flex flex-wrap items-center gap-3">
                                    <button type="button" @click="clearPad()" class="tw-btn-secondary">
                                        <i class="fas fa-eraser mr-2"></i> Clear
                                    </button>
                                    <button type="button"
                                            @click="save()"
                                            :disabled="isSaving"
                                            class="tw-btn-primary">
                                        <span x-show="!isSaving"><i class="fas fa-save mr-2"></i> Save signature</span>
                                        <span x-show="isSaving" x-cloak><i class="fas fa-spinner fa-spin mr-2"></i> Saving…</span>
                                    </button>
                                    <template x-if="isSigned && signedAt">
                                        <span class="text-xs text-text-muted ml-auto">
                                            <i class="fas fa-check-circle text-success mr-1"></i>
                                            Last signed <span x-text="new Date(signedAt).toLocaleString()"></span>
                                        </span>
                                    </template>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="tw-card">
                        <div class="px-6 py-4 border-b border-border">
                            <h2 class="text-lg font-semibold text-text flex items-center gap-2 m-0">
                                <i class="fas fa-download text-primary"></i>
                                Export
                            </h2>
                            <p class="text-sm text-text-muted mt-1">Generate and download the full CRA compliance bundle</p>
                        </div>
                        <div class="p-6 space-y-3">
                            <button @click="refreshStale()"
                                    :disabled="isRefreshing"
                                    class="tw-btn-secondary w-full">
                                <span x-show="!isRefreshing"><i class="fas fa-sync mr-2"></i> Refresh Stale Documents</span>
                                <span x-show="isRefreshing" x-cloak><i class="fas fa-spinner fa-spin mr-2"></i> Refreshing...</span>
                            </button>
                            {# Prominent DoC preview — CRA Article 28 declaration must be reviewed before signing #}
                            <button type="button"
                                    @click="previewDocument('declaration_of_conformity', 'Declaration of Conformity')"
                                    data-testid="preview-doc-btn"
                                    class="tw-btn-secondary w-full">
                                <i class="fas fa-eye mr-2"></i> Preview Declaration of Conformity
                            </button>
                            {# On-demand DoC PDF — sidesteps the full bundle export when an auditor or notified body just wants the signed Article 28 declaration as a PDF #}
                            <button type="button"
                                    @click="downloadDocumentPdf('declaration_of_conformity', 'Declaration of Conformity')"
                                    :disabled="downloadingDocPdf"
                                    data-testid="download-doc-pdf-btn"
                                    class="tw-btn-secondary w-full">
                                <span x-show="!downloadingDocPdf"><i class="fas fa-file-pdf mr-2"></i> Download Declaration of Conformity (PDF)</span>
                                <span x-show="downloadingDocPdf" x-cloak><i class="fas fa-spinner fa-spin mr-2"></i> Preparing PDF…</span>
                            </button>
                            <button @click="exportBundle()"
                                    :disabled="isExporting || !exportAvailable"
                                    class="tw-btn-primary w-full">
                                <span x-show="!isExporting"><i class="fas fa-download mr-2"></i> Export Compliance Bundle</span>
                                <span x-show="isExporting" x-cloak><i class="fas fa-spinner fa-spin mr-2"></i> Exporting...</span>
                            </button>
                            <template x-if="!overallReady">
                                <p class="text-xs text-text-muted text-center">Complete all steps and answer all controls to enable export.</p>
                            </template>
                        </div>
                    </div>
                    {# Bundle manifest preview — what's actually in the ZIP #}
                    <template x-if="lastExport">
                        <div class="tw-card" data-testid="bundle-manifest-card">
                            <div class="px-6 py-4 border-b border-border flex items-center justify-between">
                                <div>
                                    <h2 class="text-lg font-semibold text-text flex items-center gap-2 m-0">
                                        <i class="fas fa-box-open text-primary"></i>
                                        Last Export Bundle
                                    </h2>
                                    <p class="text-sm text-text-muted mt-1">
                                        <span x-text="lastExport.files?.length || 0"></span> files · format_version
                                        <code class="text-xs" x-text="lastExport.format_version || '—'"></code>
                                    </p>
                                </div>
                                <template x-if="lastExport.manufacturer_is_placeholder">
                                    <span class="tw-badge-danger text-xs"
                                          data-testid="bundle-placeholder-badge"
                                          title="Manufacturer field is still a placeholder in this bundle. Re-export after configuring a real manufacturer.">
                                        <i class="fas fa-triangle-exclamation mr-1"></i>
                                        Placeholder manufacturer
                                    </span>
                                </template>
                            </div>
                            <div class="p-6 space-y-4">
                                {# Integrity block — lastExport.content_hash is SHA-256 of the ZIP bytes; manifest self-hash lives in metadata/manifest.sha256 and is verified by the sha256sum command below. #}
                                <template x-if="lastExport.integrity">
                                    <div class="text-xs text-text-muted space-y-1">
                                        <p class="m-0">
                                            <i class="fas fa-shield-halved text-text-muted mr-1"></i>
                                            Verify the manifest from the extracted bundle root:
                                        </p>
                                        <pre class="bg-surface-hover text-text rounded p-2 overflow-x-auto text-xs m-0"><code>sha256sum -c metadata/manifest.sha256</code></pre>
                                        <p class="m-0 mt-1">Bundle SHA-256 (ZIP bytes stored in sbomify):</p>
                                        <code class="font-mono text-xs break-all"
                                              data-testid="bundle-content-hash"
                                              x-text="lastExport.content_hash"></code>
                                    </div>
                                </template>
                                {# Per-file manifest summary #}
                                <div class="border border-border rounded-lg overflow-hidden">
                                    <div class="px-3 py-2 bg-surface-hover text-xs font-medium text-text-muted flex items-center justify-between">
                                        <span>Files listed in manifest
                                            <span class="tooltip text-[10px] text-text-muted ml-1"
                                                  title="Excludes the integrity primitives themselves (metadata/manifest.json, metadata/manifest.sha256, metadata/INTEGRITY.md). The ZIP contains three more entries than shown here.">(?)</span>
                                        </span>
                                        <span class="font-mono"
                                              x-text="(lastExport.files?.length || 0) + ' entries'"></span>
                                    </div>
                                    <div class="divide-y divide-border max-h-64 overflow-y-auto">
                                        <template x-for="f in lastExport.files || []" :key="f.path">
                                            <div class="px-3 py-2 text-xs flex items-start gap-3">
                                                <code class="font-mono text-text flex-1 break-all"
                                                      data-testid="bundle-file-path"
                                                      x-text="f.path"></code>
                                                <span class="shrink-0 text-text-muted"
                                                      x-text="f.cra_reference"
                                                      :title="f.cra_reference"></span>
                                            </div>
                                        </template>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </template>
                    {# Mark Assessment Complete — uses fa-circle-check (solid, high-contrast) instead of fa-flag-checkered which vanished against bg-green-100 in light mode. #}
                    <template x-if="overallReady">
                        <div class="tw-card border-green-300 dark:border-green-700">
                            <div class="p-6">
                                <div class="flex items-start gap-4">
                                    <div class="shrink-0 w-10 h-10 rounded-full bg-green-100 dark:bg-green-900/40 flex items-center justify-center">
                                        <i class="fas fa-circle-check text-xl text-green-600 dark:text-green-400"></i>
                                    </div>
                                    <div class="flex-1">
                                        <h3 class="font-semibold text-text m-0">Ready to Complete</h3>
                                        <p class="text-sm text-text-muted mt-1">
                                            All steps are complete and controls have been assessed. Mark this assessment as finished to lock in results.
                                        </p>
                                        <button @click="finishAssessment()"
                                                :disabled="isFinishing"
                                                class="tw-btn-primary mt-3">
                                            <span x-show="!isFinishing"><i class="fas fa-circle-check mr-2"></i> Mark Assessment Complete</span>
                                            <span x-show="isFinishing" x-cloak><i class="fas fa-spinner fa-spin mr-2"></i> Completing...</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </template>
                </div>
                {# Right: Documents #}
                <div class="space-y-3">
                    <h2 class="text-lg font-semibold text-text flex items-center gap-2">
                        <i class="fas fa-file-lines text-primary"></i>
                        Documents
                    </h2>
                    <p class="text-sm text-text-muted -mt-1">Generated compliance documents and their current status</p>
                    <template x-for="doc in docKinds" :key="doc.key">
                        {% include "compliance/components/document_card.html.j2" %}
                    </template>
                </div>
            </div>
            {# Preview Modal #}
            <template x-teleport="body">
                <div x-show="showPreviewModal"
                     x-transition.opacity
                     class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
                     @click.self="showPreviewModal = false"
                     @keydown.escape.window="showPreviewModal = false">
                    <div role="dialog"
                         aria-modal="true"
                         aria-labelledby="preview-modal-title"
                         class="bg-surface rounded-xl shadow-xl max-w-3xl w-full max-h-[80vh] flex flex-col">
                        <div class="px-6 py-4 border-b border-border flex items-center justify-between">
                            <h3 id="preview-modal-title"
                                class="font-semibold text-text m-0"
                                x-text="previewTitle"></h3>
                            <button @click="showPreviewModal = false"
                                    aria-label="Close preview"
                                    class="tw-btn-ghost p-2">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                        <div class="p-6 overflow-y-auto">
                            <template x-if="isLoadingPreview">
                                <div class="flex justify-center py-8">
                                    <div class="animate-spin w-8 h-8 border-4 border-primary border-t-transparent rounded-full"></div>
                                </div>
                            </template>
                            <template x-if="!isLoadingPreview">
                                {% comment %}
                                prose-code:before/after override strips the literal backticks Tailwind Typography
                                wraps inline-code spans with. They were rendering as visible characters around
                                each path in DoC §8 (the markdown emits proper <code> spans; the backticks were
                                CSS decoration, not template output).
                                {% endcomment %}
                                <div class="prose prose-sm max-w-none text-text prose-headings:text-text prose-strong:text-text prose-a:text-primary prose-code:text-text prose-code:before:content-none prose-code:after:content-none prose-table:text-sm prose-td:py-1 prose-th:py-1 prose-hr:border-border/50"
                                     x-html="previewContent"></div>
                            </template>
                        </div>
                    </div>
                </div>
            </template>
        </div>
        {# Footer navigation #}
        <div class="flex justify-between items-center mt-8 pt-6 border-t border-border">
            {% if step > 1 %}
                <a href="{% url 'compliance:cra_step' assessment_id=assessment_id step=step|add:'-1' %}"
                   class="tw-btn-secondary">
                    <i class="fas fa-arrow-left mr-2"></i> Back
                </a>
            {% else %}
                <div>{# spacer #}</div>
            {% endif %}
            <div>{# spacer #}</div>
        </div>
    </div>
{% endblock step_wrapper %}
