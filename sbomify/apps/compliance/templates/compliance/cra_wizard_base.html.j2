{% extends "core/dashboard_base.html.j2" %}
{% block title %}CRA Compliance — {{ step_name }} — sbomify{% endblock %}
{% block sidebar_content %}
    {# CRA sidebar navigation — only shown when sidebar is expanded #}
    <div x-show="!sidebarCollapsed"
         x-cloak
         class="px-3 py-4 border-t border-border">
        <h3 class="px-4 text-xs font-semibold text-text-muted uppercase tracking-wider mb-2">Compliance</h3>
        <a href="{% url 'compliance:cra_product_list' %}"
           class="flex items-center gap-3 px-4 h-9 rounded-xl text-sm text-text transition-all duration-200 sidebar-link-hover">
            <i class="fas fa-shield-halved text-sm"></i>
            <span>CRA Wizard</span>
        </a>
    </div>
{% endblock sidebar_content %}
{% block dashboard_content %}
    {# Stepper #}
    {% include "compliance/components/cra_stepper.html.j2" %}
    {# Each step template overrides this block with x-data wrapping both content and footer #}
    {% block step_wrapper %}
    {% endblock step_wrapper %}
{% endblock dashboard_content %}
