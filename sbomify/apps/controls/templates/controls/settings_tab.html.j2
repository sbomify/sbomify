{# Catalog Activation Card #}
<div class="tw-settings-card mb-6">
    <div class="px-6 py-4 border-b border-border">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg {% if active_catalogs %}bg-success/10{% else %}bg-border/30{% endif %} flex items-center justify-center">
                <i class="fas {% if active_catalogs %}fa-list-check text-success{% else %}fa-list-check text-text-muted{% endif %}"></i>
            </div>
            <div>
                <h5 class="text-lg font-semibold text-text m-0">Compliance Controls</h5>
                <p class="text-text-muted text-sm m-0">Manage compliance controls for your workspace</p>
            </div>
        </div>
    </div>
    <div class="p-6">
        {% if not active_catalogs %}
            <p class="text-text-muted text-sm mb-4">
                Activate one or more compliance catalogs to track controls and display compliance status on your Trust Center.
            </p>
        {% endif %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            {% for catalog_key, catalog_name, catalog_label, catalog_icon in available_catalogs %}
                {% if catalog_name in active_catalog_names %}
                    <form method="post" action="{% url 'controls:catalog_action' team.key %}">
                        {% csrf_token %}
                        <input type="hidden" name="controls_catalog_action" value="deactivate">
                        {% for ac in active_catalogs %}
                            {% if ac.catalog.name == catalog_name %}<input type="hidden" name="catalog_id" value="{{ ac.catalog.id }}">{% endif %}
                        {% endfor %}
                        <input type="hidden" name="active_tab" value="controls">
                        <button type="submit"
                                class="w-full flex flex-col items-center gap-2 p-4 rounded-lg border-2 border-success/40 bg-success/5 hover:bg-danger/5 hover:border-danger/40 transition-all cursor-pointer group">
                            <i class="fas {{ catalog_icon }} text-success text-lg group-hover:hidden"></i>
                            <i class="fas fa-times-circle text-danger text-lg hidden group-hover:block"></i>
                            <span class="text-sm font-medium text-text text-center">{{ catalog_label }}</span>
                            <span class="text-xs font-medium text-success group-hover:hidden">Active</span>
                            <span class="text-xs font-medium text-danger hidden group-hover:block">Deactivate</span>
                        </button>
                    </form>
                {% else %}
                    <form method="post" action="{% url 'controls:catalog_action' team.key %}">
                        {% csrf_token %}
                        <input type="hidden" name="controls_catalog_action" value="activate">
                        <input type="hidden" name="catalog_name" value="{{ catalog_key }}">
                        <input type="hidden" name="active_tab" value="controls">
                        <button type="submit"
                                class="w-full flex flex-col items-center gap-2 p-4 rounded-lg border-2 border-dashed border-border hover:border-primary hover:bg-primary/5 transition-all cursor-pointer bg-background/50">
                            <i class="fas {{ catalog_icon }} text-text-muted text-lg"></i>
                            <span class="text-sm font-medium text-text text-center">{{ catalog_label }}</span>
                            <span class="text-xs text-primary font-medium">Activate</span>
                        </button>
                    </form>
                {% endif %}
            {% endfor %}
            {# OSCAL Import Card #}
            <div x-data="{ showImport: false, importing: false, error: '', fileName: '' }"
                 class="relative">
                <button type="button"
                        @click="showImport = !showImport"
                        class="w-full flex flex-col items-center gap-2 p-4 rounded-lg border-2 border-dashed border-border hover:border-primary hover:bg-primary/5 transition-all cursor-pointer bg-background/50">
                    <i class="fas fa-file-import text-text-muted text-lg"></i>
                    <span class="text-sm font-medium text-text text-center">Import OSCAL</span>
                    <span class="text-xs text-primary font-medium">Upload JSON</span>
                </button>
                <div x-show="showImport"
                     x-cloak
                     x-transition
                     class="absolute z-10 top-full left-0 right-0 mt-2 p-4 rounded-lg border border-border bg-card shadow-lg">
                    <p class="text-xs text-text-muted mb-3">
                        Upload an <a href="https://pages.nist.gov/OSCAL/"
    target="_blank"
    rel="noopener"
    class="text-primary hover:underline">OSCAL</a> catalog JSON file (NIST 800-53, CIS, etc.)
                    </p>
                    <input type="file"
                           accept=".json"
                           class="tw-form-input text-xs w-full mb-2"
                           @change="fileName = $el.files[0]?.name || ''"
                           x-ref="oscalFile">
                    <template x-if="error">
                        <p class="text-danger text-xs mb-2" x-text="error"></p>
                    </template>
                    <div class="flex gap-2">
                        <button type="button"
                                class="tw-btn-primary tw-btn-sm flex-1 text-xs"
                                :disabled="importing || !fileName"
                                @click=" importing = true; error = ''; const file = $refs.oscalFile.files[0]; if (!file) { error = 'Select a file'; importing = false; return; } file.text().then(text => { return fetch('/api/v1/controls/catalogs/import-oscal/', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRFToken': document.querySelector('[name=csrfmiddlewaretoken]').value }, body: text }); }).then(r => r.json().then(d => ({ok: r.ok, data: d}))).then(({ok, data}) => { importing = false; if (ok) { window.location.reload(); } else { error = data.detail || 'Import failed'; } }).catch(e => { importing = false; error = e.message; }); ">
                            <span x-show="!importing">Import</span>
                            <span x-show="importing">Importing...</span>
                        </button>
                        <button type="button"
                                class="tw-btn-outline tw-btn-sm text-xs"
                                @click="showImport = false; error = ''">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
        {% if active_catalogs %}
            <p class="text-text-muted text-xs mt-3">
                {{ active_catalogs|length }} framework{{ active_catalogs|length|pluralize }} active. Click an active framework to deactivate it.
            </p>
        {% endif %}
    </div>
</div>
{# Controls Tables — one per active catalog #}
{% for catalog_data in active_catalogs %}
    {% with controls_catalog=catalog_data.catalog controls_categories=catalog_data.categories controls_total_count=catalog_data.total_count %}
        {% include "controls/controls_table.html.j2" %}
    {% endwith %}
{% endfor %}
