{# Catalog Activation Card #}
<div class="tw-settings-card mb-6">
    <div class="px-6 py-4 border-b border-border">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg {% if controls_catalog %}bg-success/10{% else %}bg-border/30{% endif %} flex items-center justify-center">
                <i class="fas {% if controls_catalog %}fa-shield-halved text-success{% else %}fa-shield-halved text-text-muted{% endif %}"></i>
            </div>
            <div>
                <h5 class="text-lg font-semibold text-text m-0">Compliance Controls</h5>
                <p class="text-text-muted text-sm m-0">Manage SOC 2 Type II compliance controls for your workspace</p>
            </div>
        </div>
    </div>
    <div class="p-6">
        {% if controls_catalog %}
            <div class="flex items-center justify-between gap-4 mb-4">
                <div>
                    <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-medium bg-success/10 text-success">
                        <i class="fas fa-check-circle"></i>
                        Active
                    </span>
                    <span class="ml-3 text-text font-medium">{{ controls_catalog.name }}</span>
                    <span class="text-text-muted text-sm ml-1">v{{ controls_catalog.version }}</span>
                </div>
                <form method="post"
                      action="{% url 'controls:catalog_action' team.key %}"
                      class="flex-shrink-0">
                    {% csrf_token %}
                    <input type="hidden" name="controls_catalog_action" value="deactivate">
                    <input type="hidden" name="catalog_id" value="{{ controls_catalog.id }}">
                    <input type="hidden" name="active_tab" value="controls">
                    <button type="submit" class="tw-btn-danger tw-btn-sm">
                        <i class="fas fa-times mr-1"></i>Deactivate
                    </button>
                </form>
            </div>
            <p class="text-text-muted text-sm">
                {{ controls_catalog.controls.count }} controls loaded across {{ controls_categories|length }} categories.
            </p>
        {% else %}
            <div class="flex items-center justify-between gap-4 mb-4">
                <div>
                    <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-medium bg-border/50 text-text-muted">
                        No catalog active
                    </span>
                </div>
                <form method="post"
                      action="{% url 'controls:catalog_action' team.key %}"
                      class="flex-shrink-0">
                    {% csrf_token %}
                    <input type="hidden" name="controls_catalog_action" value="activate">
                    <input type="hidden" name="active_tab" value="controls">
                    <button type="submit" class="tw-btn-primary">
                        <i class="fas fa-shield-halved mr-2"></i>Activate SOC 2 Type II
                    </button>
                </form>
            </div>
            <p class="text-text-muted text-sm">
                Activate a compliance catalog to track your SOC 2 Type II controls and display compliance status on your Trust Center.
            </p>
        {% endif %}
    </div>
</div>
{# Controls Table (only when catalog is active) #}
{% if controls_catalog and controls_categories %}
    {% include "controls/controls_table.html.j2" %}
{% endif %}
