{% if posthog_api_key %}
    <div x-data="analyticsConsent()"
         x-show="visible"
         x-cloak
         class="fixed bottom-4 left-4 right-4 sm:left-auto sm:right-4 sm:max-w-sm z-50 bg-surface border border-border rounded-xl shadow-lg p-4">
        <p class="text-sm text-text-secondary mb-3">
            We use anonymized analytics (hashed identifiers and usage events) to improve sbomify. You can change this anytime in settings.
        </p>
        <div class="flex gap-2">
            <button @click="accept()" class="tw-btn-primary tw-btn-sm">Accept</button>
            <button @click="decline()" class="tw-btn-ghost tw-btn-sm">Decline</button>
        </div>
    </div>
    <script>
    function analyticsConsent() {
        var CONSENT_KEY = 'sbomify-analytics-consent';
        return {
            visible: false,
            init() {
                if (typeof posthog === 'undefined') return;
                var choice = localStorage.getItem(CONSENT_KEY);
                if (choice !== null) return;
                this.visible = true;
            },
            accept() {
                localStorage.setItem(CONSENT_KEY, 'accepted');
                posthog.opt_in_capturing();
                this.visible = false;
            },
            decline() {
                localStorage.setItem(CONSENT_KEY, 'declined');
                posthog.opt_out_capturing();
                this.visible = false;
            }
        };
    }
    </script>
{% endif %}
