{% load static %}
{% load django_vite %}
{% load django_htmx %}
{% load cache %}
{% load schema_tags %}
<!DOCTYPE html>
<html lang="en">
    <head>
        {% block head %}
            <meta charset="utf-8">
            {# Critical: Apply theme before any content renders to prevent flash #}
            {# NOTE: Storage key 'sbomify-theme' must match STORAGE_KEY in theme-manager.ts #}
            <script>
                (function() {
                    var theme;
                    try { theme = localStorage.getItem('sbomify-theme'); } catch(e) { /* blocked storage */ }
                    if (!theme || ['dark','light','system'].indexOf(theme) === -1) theme = 'dark';
                    var effectiveTheme = theme;
                    if (theme === 'system') {
                        effectiveTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                    }
                    document.documentElement.classList.add(effectiveTheme);
                })();
            </script>
            <meta http-equiv="X-UA-Compatible" content="IE=edge">
            <meta name="viewport" content="width=device-width, initial-scale=1">
            <meta name="color-scheme" content="dark light">
            <meta name="theme-color" content="#0F0F2D">
            <meta name="description" content="Software Bill of Materials management">
            <meta name="keywords"
                  content="SBOM SBOMs software bill of materials security">
            <!-- Favicon -->
            <link rel="apple-touch-icon"
                  sizes="180x180"
                  href="{% static 'img/favicons/apple-touch-icon.png' %}">
            <link rel="icon"
                  type="image/png"
                  sizes="32x32"
                  href="{% static 'img/favicons/favicon-32x32.png' %}">
            <link rel="icon"
                  type="image/png"
                  sizes="16x16"
                  href="{% static 'img/favicons/favicon-16x16.png' %}">
            <link rel="icon"
                  type="image/svg+xml"
                  href="{% static 'img/favicons/favicon.svg' %}">
            <link rel="manifest" href="{% static 'dist/manifest.webmanifest' %}">
            <!-- Schema.org metadata -->
            {% schema_org_metadata %}
            <!-- Open Graph / Facebook -->
            <meta property="og:type" content="website">
            <meta property="og:url" content="{{ request.build_absolute_uri }}">
            <meta property="og:title"
                  content="{% block og_title %}sbomify - Software Bill of Materials Management{% endblock %}">
            <meta property="og:description"
                  content="{% block og_description %}Manage and track your software bill of materials with ease. Secure your software supply chain with sbomify.{% endblock %}">
            <meta property="og:image"
                  content="{{ request.scheme }}://{{ request.get_host }}{% static 'img/sbomify-social.png' %}">
            <meta property="og:image:width" content="1200">
            <meta property="og:image:height" content="630">
            <meta property="og:image:type" content="image/png">
            <meta property="og:image:alt"
                  content="sbomify logo - From Zero to SBOM Hero">
            <!-- Twitter -->
            <meta property="twitter:card" content="summary_large_image">
            <meta property="twitter:url" content="{{ request.build_absolute_uri }}">
            <meta property="twitter:title"
                  content="{% block twitter_title %}sbomify - Software Bill of Materials Management{% endblock %}">
            <meta property="twitter:description"
                  content="{% block twitter_description %}Manage and track your software bill of materials with ease. Secure your software supply chain with sbomify.{% endblock %}">
            <meta property="twitter:image"
                  content="{{ request.scheme }}://{{ request.get_host }}{% static 'img/sbomify-social.png' %}">
            {% if posthog_api_key %}<link rel="dns-prefetch" href="{{ posthog_host }}">{% endif %}
            <!-- Fonts -->
            <link rel="preconnect" href="https://fonts.googleapis.com">
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
            <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
                  rel="stylesheet">
            <!-- Icons -->
            <link href="{% static 'css/fontawesome.min.css' %}" rel="stylesheet">
            {# Critical: Prevent flash of unstyled content #}
            <style>
                [x-cloak] { display: none !important; }
                /* Critical inline styles to prevent layout flash */
                html.dark { background-color: #0A0A23; color: #fff; }
                html.light { background-color: #f8fafc; color: #1e293b; }
                html { min-height: 100%; }
                body { min-height: 100vh; opacity: 0; transition: opacity 0.1s ease-in; }
                body.ready { opacity: 1; }
            </style>
            <script>
                // Show body once DOM is ready
                document.addEventListener('DOMContentLoaded', function() {
                    document.body.classList.add('ready');
                });
                // Fallback: show body after short delay if DOMContentLoaded already fired
                if (document.readyState !== 'loading') {
                    document.body?.classList.add('ready');
                }
            </script>
            <noscript>
                <style>body { opacity: 1 !important; }</style>
            </noscript>
            {% block styles %}{% endblock %}
            <link rel="stylesheet"
                  href="{% vite_asset_url 'sbomify/assets/css/tailwind.src.css' %}">
            <title>
                {% block title %}sbomify{% endblock %}
            </title>
        {% endblock %}
        {% htmx_script %}
        {% vite_hmr_client %}
    </head>
    <body class="bg-background text-text font-sans antialiased"
          hx-ext="alpine-morph">
        <a href="#main-content"
           class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[999] focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:rounded-lg focus:shadow-lg focus:text-sm focus:font-medium">
            Skip to main content
        </a>
        {% block main %}
            {% block content %}{% endblock %}
        {% endblock %}
        <!-- Global Modals -->
        <div id="global-modal-container">
            {% if add_workspace_form %}
                {% url 'teams:teams_dashboard' as teams_dashboard_url %}
                {% include "components/modals/form_modal.html.j2" with modal_id="add-workspace-modal" modal_title="Add Workspace" form=add_workspace_form form_action=teams_dashboard_url submit_text="Add Workspace" icon="fa-plus" %}
            {% endif %}
        </div>
        <!-- Global Toast Notifications -->
        {% include "components/tw/toast_container.html.j2" %}
        <!-- Global Confirmation Modal -->
        {% include "components/tw/confirm_modal.html.j2" %}
        {% block scripts %}{% endblock %}
        <!-- HTMX Alpine-Morph Extension (defer so it runs after HTMX core from head) -->
        <script src="{% static 'js/htmx-ext-alpine-morph.min.js' %}" defer></script>
        <!-- Sentry configuration -->
        <script>
            window.__SENTRY_CONFIG__ = {
                dsn: "{{ sentry_dsn_frontend }}",
                release: "{{ sbomify_version }}"
            };
        </script>
        {% vite_asset 'sbomify/apps/core/js/main.ts' %}
        {% if posthog_api_key %}
            <!-- PostHog analytics -->
            {{ posthog_api_key|json_script:"posthog-api-key" }}
            {{ posthog_host|json_script:"posthog-host" }}
            {% if posthog_identify %}{{ posthog_identify|json_script:"posthog-identify" }}{% endif %}
            <script>
                !function(t,e){var o,n,p,r;e.__SV||(window.posthog && window.posthog.__loaded)||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init zr Wr fi Br Gr ci Nr Hr capture Ui calculateEventProperties Kr register register_once register_for_session unregister unregister_for_session Zr getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSurveysLoaded onSessionId getSurveys getActiveMatchingSurveys renderSurvey displaySurvey cancelPendingSurvey canRenderSurvey canRenderSurveyAsync identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getSessionProperty Xr Jr createPersonProfile Qr jr ts opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing get_explicit_consent_status is_capturing clear_opt_in_out_capturing Vr debug O Yr getPageViewId captureTraceFeedback captureTraceMetric Or".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
                (function() {
                    var apiKey = JSON.parse(document.getElementById('posthog-api-key').textContent);
                    var apiHost = JSON.parse(document.getElementById('posthog-host').textContent);
                    posthog.init(apiKey, {
                        api_host: apiHost,
                        defaults: '2026-01-30',
                        person_profiles: 'identified_only',
                    });
                    var idEl = document.getElementById('posthog-identify');
                    if (idEl) {
                        var identity = JSON.parse(idEl.textContent);
                        posthog.identify(identity.distinct_id, {
                            email: identity.email,
                            name: identity.name,
                        });
                        if (identity.workspace_key) {
                            posthog.group('workspace', identity.workspace_key);
                        }
                    }
                })();
            </script>
        {% endif %}
    </body>
</html>
