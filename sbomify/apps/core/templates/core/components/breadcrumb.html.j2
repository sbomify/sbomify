{% if crumbs %}
    <nav aria-label="breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-2 bg-surface px-4 py-3 md:px-6 md:py-4 m-0 text-sm border border-border rounded-xl shadow-sm list-none">
            {% for crumb in crumbs %}
                <li class="flex items-center {% if crumb.active %}text-text font-semibold{% else %}text-text-muted{% endif %}"
                    {% if crumb.active %}aria-current="page"{% endif %}
                    {% if crumb.title %}title="{{ crumb.title }}"{% endif %}>
                    {% if not forloop.first %}<span class="text-text-muted mx-2 font-light">›</span>{% endif %}
                    {% if crumb.url and not crumb.active %}
                        <a href="{{ crumb.url }}"
                           class="flex items-center px-2 py-1 rounded-md text-text-muted hover:text-text hover:bg-background transition-colors font-medium no-underline"
                           {% if crumb.title %}title="{{ crumb.title }}"{% endif %}>
                            <i class="{{ crumb.icon }} mr-1.5 opacity-80"></i>{{ crumb.name }}
                        </a>
                    {% else %}
                        <span class="flex items-center px-2 py-1">
                            <i class="{{ crumb.icon }} mr-1.5 opacity-80"></i>{{ crumb.name }}
                        </span>
                    {% endif %}
                </li>
            {% endfor %}
        </ol>
    </nav>
{% endif %}
