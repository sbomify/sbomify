<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="sbomify platform notification">
        <meta name="keywords"
              content="sbomify, sbom, software bill of materials, security">
        <title>
            {% block title %}sbomify{% endblock %}
        </title>
        <style>
            body {
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
                line-height: 1.6;
                color: #333333;
                margin: 0;
                padding: 0;
                background-color: #f8fafc;
            }

            .email-wrapper {
                background-color: #f8fafc;
            }

            .email-container {
                background-color: #ffffff;
            }

            .email-body {
                padding: 40px;
            }

            .logo-cell {
                background-color: #0f172a;
                padding: 24px;
                text-align: center;
            }

            .tagline-cell {
                background-color: #0f172a;
                padding: 0 24px 20px 24px;
                text-align: center;
                color: #cbd5e1;
                font-size: 14px;
            }

            h1 {
                color: #1e293b;
                font-size: 24px;
                margin-top: 0;
                margin-bottom: 16px;
                font-weight: 600;
            }

            h2 {
                color: #4059d0;
                font-size: 20px;
                margin-top: 32px;
                margin-bottom: 16px;
            }

            h3 {
                color: #1e293b;
                font-size: 18px;
                margin-bottom: 12px;
                font-weight: 600;
            }

            p {
                margin-top: 16px;
                margin-bottom: 16px;
                color: #475569;
            }

            ul {
                margin-top: 16px;
                margin-bottom: 16px;
                padding-left: 24px;
                color: #475569;
            }

            li {
                margin-top: 8px;
                margin-bottom: 8px;
            }

            a.button {
                display: inline-block;
                padding: 12px 24px;
                background-color: #4059d0;
                color: #ffffff;
                margin-top: 16px;
                margin-bottom: 16px;
                font-weight: 500;
                text-align: center;
            }

            .button-secondary {
                background-color: #64748b;
            }

            .text-secondary {
                color: #64748b;
                font-size: 14px;
            }

            .highlight-box {
                background-color: #f1f5f9;
                border-left: 4px solid #4059d0;
                padding: 16px;
                margin-top: 24px;
                margin-bottom: 24px;
            }

            .feature-list {
                list-style: none;
                padding-left: 0;
            }

            .feature-list li {
                padding-top: 8px;
                padding-bottom: 8px;
            }

            .feature-list li .check {
                color: #10b981;
                font-weight: bold;
                margin-right: 8px;
            }

            .user-info {
                background-color: #fef3c7;
                border-top: 1px solid #f59e0b;
                border-right: 1px solid #f59e0b;
                border-bottom: 1px solid #f59e0b;
                border-left: 1px solid #f59e0b;
                padding: 12px;
                margin-top: 16px;
                margin-bottom: 16px;
                font-size: 14px;
            }

            a {
                color: #4059d0;
            }

            .footer {
                background-color: #f1f5f9;
                padding: 24px 40px;
                text-align: center;
                color: #64748b;
                font-size: 14px;
            }

            .footer a {
                color: #4059d0;
            }

            .unsubscribe {
                margin-top: 16px;
                font-size: 12px;
                color: #94a3b8;
            }

            /* Narrow-viewport (phone) tweaks. Padding for responsive
               elements is defined in the `<style>` block (not inline) so
               the media query overrides win on class-selector specificity
               alone — no `!important` needed. Clients that strip
               `<style>` will lose padding here, but those same clients
               don't process @media either, so the responsive layer is
               unaffected. */
            .email-wrapper-cell {
                padding: 20px;
            }

            @media only screen and (max-width: 620px) {
                .email-container {
                    width: 100%;
                    max-width: 100%;
                }

                .email-wrapper-cell {
                    padding: 12px;
                }

                .email-body {
                    padding: 24px;
                }

                .footer {
                    padding: 20px 24px;
                }
            }
</style>
</head>
<body>
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" bgcolor="#f8fafc" class="email-wrapper">
<tr>
<td align="center" class="email-wrapper-cell">
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" bgcolor="#ffffff" class="email-container">
<tr>
<td align="center" bgcolor="#0f172a" style="background-color: #0f172a; padding: 24px; color: #ffffff" class="logo-cell">
<img src="{{ base_url }}/static/img/sbomify-white.svg" alt="sbomify" height="40" width="221" border="0" style="color: #ffffff; font-weight: 600; font-size: 20px">
</td>
</tr>
<tr>
<td align="center" bgcolor="#0f172a" style="background-color: #0f172a; color: #cbd5e1; padding: 0 24px 20px 24px; font-size: 14px" class="tagline-cell">
The Security Artifact Hub
</td>
</tr>
<tr>
<td class="email-body">
{% block content %}{% endblock %}
{% block signoff %}
<p>
Cheers,
<br>
<strong>The sbomify Team</strong>
</p>
{% endblock %}
</td>
</tr>
<tr>
<td bgcolor="#f1f5f9" align="center" style="background-color: #f1f5f9; text-align: center; color: #64748b; font-size: 14px" class="footer">
<p>
Questions? We're here to help. <a href="{{ base_url }}/support/contact/">Get in touch</a>
</p>
{% now "Y" as this_year %}
<p>© {{ current_year|default:this_year }} sbomify. All rights reserved.</p>
</td>
</tr>
</table>
</td>
</tr>
</table>
</body>
</html>
