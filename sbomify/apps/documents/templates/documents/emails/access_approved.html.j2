{% extends "core/emails/base.html.j2" %}
{% block title %}Your Access Request Has Been Approved{% endblock %}
{% block content %}
    <h1>Access request approved</h1>
    {# djlint:off #}
    <p>Hi {% if user.first_name %}{{ user.first_name }}{% else %}there{% endif %},</p>
    {# djlint:on #}
    <p>
        Your request for access to the workspace <strong>{{ team.name }}</strong> has been approved.
        You can now view gated documents and SBOMs in the Trust Center.
    </p>
    <p style="text-align: center; margin: 32px 0;">
        <a href="{{ login_link }}" class="button">View Trust Center</a>
    </p>
{% endblock %}
