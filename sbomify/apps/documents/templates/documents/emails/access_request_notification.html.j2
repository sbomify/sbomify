{% extends "core/emails/base.html.j2" %}
{% block title %}New Access Request{% endblock %}
{% block content %}
    <h1>New access request</h1>
    {# djlint:off #}
    <p>Hi {% if admin_user.first_name %}{{ admin_user.first_name }}{% else %}there{% endif %},</p>
    {# djlint:on #}
    <p>
        <strong>{{ requester_name }}</strong> ({{ requester_email }}) has requested access
        to the workspace <strong>{{ team.name }}</strong>.
    </p>
    {% if requires_nda %}
        <p>
            NDA status:
            {% if nda_signed %}
                Signed
            {% else %}
                Pending signature
            {% endif %}
        </p>
    {% endif %}
    <p style="text-align: center; margin: 32px 0;">
        <a href="{{ review_link }}" class="button">Review Request</a>
    </p>
{% endblock %}
