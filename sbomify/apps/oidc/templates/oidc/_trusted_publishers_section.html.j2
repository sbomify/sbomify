{% comment %}
  Trusted Publishers section for a Component's settings.

  Rendered both:
    * inline on first page load (via the hx-get='load' container in the
      component_details_private templates)
    * as an HTMX swap target after create/delete

  The whole section is the swap target (id="trusted-publishers-section")
  so create + delete + form errors all land back into the same shell.

  NOTE: Django's "{#" comments are SINGLE-LINE only; multi-line needs
  the {% comment %} tag — otherwise the text in between gets parsed.
{% endcomment %}
<section id="trusted-publishers-section" class="tw-card">
<header class="tw-card-header flex items-start justify-between gap-4">
<div>
<h2 class="text-lg font-semibold text-text">Trusted Publishers</h2>
<p class="text-sm text-text-muted m-0 mt-1">
Authorise a GitHub repository to push SBOMs and documents to this component
without long-lived secrets. Tokens are issued from the workflow's OIDC
identity and are valid for 15 minutes.
</p>
</div>
</header>
<div class="tw-card-body space-y-6">
{% if bindings %}
<div class="overflow-x-auto">
<table class="tw-data-table">
<thead>
<tr>
<th>Provider</th>
<th>Repository</th>
<th>Added by</th>
<th>Last used</th>
<th class="text-right">Actions</th>
</tr>
</thead>
<tbody>
{% for binding in bindings %}
<tr>
<td>
<span class="tw-badge tw-badge-secondary">
<i class="fab fa-github mr-1"></i>{{ binding.get_provider_display }}
</span>
</td>
<td>
<code class="text-sm">{{ binding.repository }}</code>
<div class="text-xs text-text-muted mt-1" title="Immutable IDs pinned at setup">
owner_id={{ binding.repository_owner_id }} · repo_id={{ binding.repository_id }}
</div>
</td>
<td class="text-sm text-text-muted">
{% if binding.created_by %}
{{ binding.created_by.get_full_name|default:binding.created_by.username }}
{% else %}
—
{% endif %}
<div class="text-xs">{{ binding.created_at|date:"Y-m-d" }}</div>
</td>
<td class="text-sm text-text-muted">
{% if binding.last_used_at %}
{{ binding.last_used_at|date:"Y-m-d H:i" }} UTC
{% else %}
<span class="italic">never</span>
{% endif %}
</td>
<td class="text-right">
<button
type="button"
class="tw-btn tw-btn-sm tw-btn-danger"
hx-post="{% url 'oidc:trusted_publisher_delete' component_id=component.id binding_id=binding.id %}"
hx-headers='{"X-CSRFToken": "{{ csrf_token }}"}'
hx-target="#trusted-publishers-section"
hx-swap="outerHTML"
hx-confirm="Remove the trusted-publisher binding for '{{ binding.repository }}'? This will immediately revoke every short-lived token it ever issued."
>
<i class="fas fa-trash"></i>
Revoke
</button>
</td>
</tr>
{% endfor %}
</tbody>
</table>
</div>
{% else %}
<div class="tw-empty-state">
<i class="fas fa-shield-halved text-2xl text-text-muted"></i>
<p class="text-sm text-text-muted mt-2">
No trusted publishers yet. Add one below to let a GitHub Actions
workflow push to this component using its OIDC identity.
</p>
</div>
{% endif %}
<form
method="post"
hx-post="{% url 'oidc:trusted_publishers' component_id=component.id %}"
hx-target="#trusted-publishers-section"
hx-swap="outerHTML"
class="space-y-3"
>
{% csrf_token %}
<div class="grid grid-cols-1 md:grid-cols-[1fr_2fr_auto] gap-3 items-end">
<div>
<label class="tw-form-label" for="id_provider">Provider</label>
{{ form.provider }}
{% if form.provider.errors %}<p class="tw-form-error">{{ form.provider.errors.0 }}</p>{% endif %}
</div>
<div>
<label class="tw-form-label" for="id_repository">Repository</label>
{{ form.repository }}
{% if form.repository.errors %}
<p class="tw-form-error">{{ form.repository.errors.0 }}</p>
{% else %}
<p class="tw-form-helper">{{ form.repository.help_text }}</p>
{% endif %}
</div>
<button type="submit" class="tw-btn tw-btn-primary">
<i class="fas fa-plus"></i>
Add publisher
</button>
</div>
</form>
<details class="border border-border rounded-md overflow-hidden">
<summary class="px-3 py-2 bg-surface cursor-pointer text-sm font-medium text-text hover:bg-surface-hover flex items-center gap-2">
<i class="fas fa-circle-info"></i>
Configure your GitHub Actions workflow
</summary>
<div class="p-4 space-y-3 text-sm">
<p>
Add this step to the workflow that should be authorised to push to
this component. The <code>audience</code> value must be exactly
<code>sbomify.com</code> — the backend rejects tokens minted for
any other audience.
</p>
{# djlint:off #}
        <pre class="bg-surface border border-border rounded p-3 text-xs overflow-x-auto text-text"><code>{% verbatim %}permissions:
  id-token: write    # required to mint the OIDC token
  contents: read

steps:
  - name: Get OIDC token from GitHub
    id: oidc
    uses: actions/github-script@v7
    with:
      script: |
        const token = await core.getIDToken('sbomify.com')
        core.setSecret(token)
        core.setOutput('token', token)

  - name: Exchange for sbomify token
    id: sbomify
    run: |
      RESP=$(curl -sS -X POST \
        -H "Authorization: Bearer ${{ steps.oidc.outputs.token }}" \
        -H "Content-Type: application/json" \
        -d '{"component_id": "{% endverbatim %}{{ component.id }}{% verbatim %}"}' \
        https://sbomify.com/api/v1/auth/oidc/github/exchange)
      echo "::add-mask::$(echo "$RESP" | jq -r '.access_token')"
      echo "token=$(echo "$RESP" | jq -r '.access_token')" &gt;&gt; "$GITHUB_OUTPUT"

  - name: Upload SBOM
    run: |
      curl -sS -X POST \
        -H "Authorization: Bearer ${{ steps.sbomify.outputs.token }}" \
        -H "Content-Type: application/json" \
        --data-binary @bom.json \
        https://sbomify.com/api/v1/sboms/artifact/cyclonedx/{% endverbatim %}{{ component.id }}
</code></pre>
{# djlint:on #}
<p class="text-xs text-text-muted">
The sbomify token expires after 15 minutes — request a fresh one
for each job that needs it.
</p>
</div>
</details>
</div>
</section>
