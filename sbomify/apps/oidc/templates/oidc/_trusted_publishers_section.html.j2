{% comment %}
    Trusted Publishers section for a Component's settings.

    Rendered both:
      * inline on first page load (via the hx-get='load' container in the
        component_details_private templates)
      * as an HTMX swap target after create/delete

    The whole section is the swap target (id="trusted-publishers-section")
    so create + delete + form errors all land back into the same shell.

    NOTE: this file is rendered by Django's template engine despite the
    ``.html.j2`` extension (sbomify-wide convention — see CLAUDE.md).
    Django's ``{# ... #}`` comments are single-line per the engine's
    spec; multi-line block comments need the ``{% comment %}`` tag,
    otherwise the second line is parsed as template content. Jinja2
    proper would tolerate multi-line ``{# ... #}`` — we don't have that
    parser here.
{% endcomment %}
<section id="trusted-publishers-section" class="tw-card">
<header class="tw-card-header">
<div class="flex items-start gap-3">
<span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary/10 flex-shrink-0">
<i class="fas fa-shield-halved text-primary"></i>
</span>
<div>
<h4 class="text-lg font-semibold text-text m-0">Trusted Publishers</h4>
<p class="text-sm text-text-muted m-0 mt-1">
Authorise a GitHub repository to push SBOMs and documents to this
component without long-lived secrets. Tokens are issued from the
workflow's OIDC identity and are valid for 15 minutes.
</p>
</div>
</div>
</header>
<div class="tw-card-body space-y-6">
{% if bindings %}
<div class="overflow-x-auto">
<table class="tw-table">
<thead>
<tr>
<th>Provider</th>
<th>Repository</th>
<th>Added by</th>
<th>Last used</th>
<th class="text-right">Actions</th>
</tr>
</thead>
<tbody>
{% for binding in bindings %}
<tr>
<td>
<span class="tw-badge tw-badge-secondary">
<i class="fab fa-github mr-1"></i>{{ binding.get_provider_display }}
</span>
</td>
<td>
<div class="flex items-center gap-2">
<code class="text-sm font-medium">{{ binding.repository }}</code>
<a href="https://github.com/{{ binding.repository }}" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-primary transition-colors" title="Open on GitHub">
<i class="fas fa-arrow-up-right-from-square text-xs"></i>
</a>
</div>
<div class="text-xs text-text-muted mt-1 font-mono" title="Immutable IDs used to defeat account-resurrection attacks. Pinned at setup for public repos; pinned from the first OIDC publish for private repos.">
{% if binding.repository_id %}
owner_id={{ binding.repository_owner_id }} ·
repo_id={{ binding.repository_id }}
{% else %}
<span class="italic">awaiting first publish — IDs pin automatically</span>
{% endif %}
</div>
</td>
<td class="text-sm text-text-muted">
{% if binding.created_by %}
{{ binding.created_by.get_full_name|default:binding.created_by.username }}
{% else %}
—
{% endif %}
<div class="text-xs">{{ binding.created_at|date:"Y-m-d" }}</div>
</td>
<td class="text-sm text-text-muted">
{% if binding.last_used_at %}
{{ binding.last_used_at|date:"Y-m-d H:i" }} UTC
{% else %}
<span class="italic">never</span>
{% endif %}
</td>
<td class="text-right">
<button type="button" class="tw-btn tw-btn-sm tw-btn-ghost text-danger hover:bg-danger/10" hx-post="{% url 'oidc:trusted_publisher_delete' component_id=component.id binding_id=binding.id %}" hx-headers='{"X-CSRFToken": "{{ csrf_token }}"}' hx-target="#trusted-publishers-section" hx-swap="outerHTML" hx-confirm="Remove the trusted-publisher binding for '{{ binding.repository }}'? This will immediately revoke every short-lived token it ever issued." title="Revoke this trusted publisher">
<i class="fas fa-trash"></i>
<span class="sr-only md:not-sr-only md:ml-1">Revoke</span>
</button>
</td>
</tr>
{% endfor %}
</tbody>
</table>
</div>
{% else %}
<div class="tw-empty-state">
<i class="fas fa-shield-halved text-3xl text-text-muted opacity-50"></i>
<p class="text-sm font-medium text-text mt-3 mb-1">No trusted publishers yet</p>
<p class="text-xs text-text-muted">
Add a GitHub repository below to let its Actions workflow push to this
component using OIDC — no long-lived API tokens required.
</p>
</div>
{% endif %}
<div class="border-t border-border pt-6">
<form method="post" hx-post="{% url 'oidc:trusted_publishers' component_id=component.id %}" hx-target="#trusted-publishers-section" hx-swap="outerHTML" class="space-y-3">
{% csrf_token %}
<div class="grid grid-cols-1 md:grid-cols-[180px_1fr_auto] gap-3 items-start">
<div>
<label class="tw-form-label" for="id_provider">Provider</label>
{{ form.provider }}
{% if form.provider.errors %}<p class="tw-form-error">{{ form.provider.errors.0 }}</p>{% endif %}
</div>
<div>
<label class="tw-form-label" for="id_repository">Repository</label>
{{ form.repository }}
{% if form.repository.errors %}
<p class="tw-form-error">{{ form.repository.errors.0 }}</p>
{% else %}
<p class="tw-form-helper">{{ form.repository.help_text }}</p>
{% endif %}
</div>
<button type="submit" class="tw-btn tw-btn-primary md:mt-7">
<i class="fas fa-plus"></i>
Add publisher
</button>
</div>
</form>
</div>
<details class="group rounded-lg bg-surface border border-border/60">
<summary class="flex items-center gap-2 px-4 py-3 cursor-pointer text-sm font-medium text-text hover:bg-background/40 rounded-lg">
<i class="fas fa-code text-text-muted"></i>
<span>Configure your GitHub Actions workflow</span>
<i class="fas fa-chevron-down text-xs text-text-muted ml-auto transition-transform group-open:rotate-180"></i>
</summary>
<div class="px-4 pb-4 pt-1 space-y-3 text-sm border-t border-border/40">
<p class="text-text-muted m-0">
Add this step to the workflow that should be authorised to push to this
component. The <code class="px-1.5 py-0.5 rounded bg-background border border-border/40 text-text font-mono text-xs">audience</code> value must be exactly
<code class="px-1.5 py-0.5 rounded bg-background border border-border/40 text-text font-mono text-xs">{{ oidc_github_audience }}</code> — the backend rejects
tokens minted for any other audience.
</p>
{# djlint:off #}
                <pre class="bg-background border border-border rounded-md p-3 text-xs overflow-x-auto text-text"><code>{% verbatim %}permissions:
  id-token: write    # required to mint the OIDC token
  contents: read

steps:
  - name: Get OIDC token from GitHub
    id: oidc
    uses: actions/github-script@v7
    with:
      script: |
        const token = await core.getIDToken('{% endverbatim %}{{ oidc_github_audience }}{% verbatim %}')
        core.setSecret(token)
        core.setOutput('token', token)

  - name: Exchange for sbomify token
    id: sbomify
    run: |
      RESP=$(curl -sS -X POST \
        -H "Authorization: Bearer ${{ steps.oidc.outputs.token }}" \
        -H "Content-Type: application/json" \
        -d '{"component_id": "{% endverbatim %}{{ component.id }}{% verbatim %}"}' \
        {% endverbatim %}{{ api_base_url }}{% verbatim %}/api/v1/auth/oidc/github/exchange)
      echo "::add-mask::$(echo "$RESP" | jq -r '.access_token')"
      echo "token=$(echo "$RESP" | jq -r '.access_token')" &gt;&gt; "$GITHUB_OUTPUT"

  - name: Upload SBOM
    run: |
      curl -sS -X POST \
        -H "Authorization: Bearer ${{ steps.sbomify.outputs.token }}" \
        -H "Content-Type: application/json" \
        --data-binary @bom.json \
        {% endverbatim %}{{ api_base_url }}{% verbatim %}/api/v1/sboms/artifact/cyclonedx/{% endverbatim %}{{ component.id }}
</code></pre>
{# djlint:on #}
<p class="text-xs text-text-muted m-0 flex items-center gap-1.5">
<i class="fas fa-clock text-text-muted"></i>
The sbomify token expires after 15 minutes — request a fresh one for each
job that needs it.
</p>
</div>
</details>
</div>
</section>
