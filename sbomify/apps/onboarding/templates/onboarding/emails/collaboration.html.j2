{% extends "core/emails/base.html.j2" %}
{% block title %}Invite your team - sbomify{% endblock %}
{% block content %}
    <h1>Invite your team, {{ user.first_name|default:user.username }}!</h1>
    <p>
        Software security is a team sport. Invite your colleagues to your workspace so
        everyone has visibility into your security posture and can respond to
        vulnerabilities faster.
    </p>
    <p>
        You can assign roles (owner, admin, or guest) to control who can do what.
        And with your <strong>Trust Center</strong>, you can share your compliance
        status with customers and partners too.
    </p>
    <p style="text-align: center; margin: 32px 0;">
        <a href="{{ app_base_url }}/workspaces/settings/" class="button">Invite Team Members</a>
    </p>
    <p>Got questions? Just reply to this email.</p>
{% endblock %}
