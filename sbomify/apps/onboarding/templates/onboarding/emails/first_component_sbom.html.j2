{% extends "core/emails/base.html.j2" %}
{% block title %}
    {% if has_created_component %}
        Upload your first SBOM - sbomify
    {% else %}
        Get started with your first SBOM - sbomify
    {% endif %}
{% endblock %}
{% block content %}
    {% if has_created_component %}
        <h1>Time to upload your first SBOM, {{ user.first_name|default:user.username }}!</h1>
        <p>
            Nice work creating your first component! Now let's upload an SBOM so sbomify
            can scan for vulnerabilities and check compliance automatically.
        </p>
        <p>You have two options:</p>
        <ul class="feature-list">
            <li>
                <strong>GitHub Action (recommended):</strong> Use our
                <a href="https://github.com/sbomify/sbomify-action" target="_blank">GitHub Action</a>
                to generate and upload SBOMs automatically with every push
            </li>
            <li>
                <strong>Manual upload:</strong> Already have an SBOM in SPDX or CycloneDX format?
                Upload it directly from the components page
            </li>
        </ul>
        <p style="text-align: center; margin: 32px 0;">
            <a href="{{ app_base_url }}/components/" class="button">Upload Your First SBOM</a>
        </p>
    {% else %}
        <h1>Ready to upload your first SBOM, {{ user.first_name|default:user.username }}?</h1>
        <p>
            Just checking in! To get started with vulnerability scanning and compliance,
            you'll need to create a component and upload an SBOM.
        </p>
        <p>It only takes a few minutes:</p>
        <ul class="feature-list">
            <li>
                <strong>Create a component</strong> for the software you want to track
            </li>
            <li>
                <strong>Upload an SBOM</strong> using our
                <a href="https://github.com/sbomify/sbomify-action" target="_blank">GitHub Action</a>
                or upload one manually (SPDX and CycloneDX supported)
            </li>
        </ul>
        <p>
            Once uploaded, sbomify will automatically scan for vulnerabilities and
            check compliance.
        </p>
        <p style="text-align: center; margin: 32px 0;">
            <a href="{{ app_base_url }}/components/" class="button">Get Started</a>
        </p>
    {% endif %}
{% endblock %}
