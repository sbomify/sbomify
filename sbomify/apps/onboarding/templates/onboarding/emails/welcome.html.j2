{% extends "core/emails/base.html.j2" %}
{% block title %}Welcome to sbomify{% endblock %}
{% block content %}
    <h1>Welcome to sbomify, {{ user.first_name|default:user.username }}!</h1>
    <p>
        Thanks for signing up. sbomify gets you from zero to SBOM hero. Manage your security artifacts,
        like SBOMs, track vulnerabilities, and meet compliance requirements, all in one place.
    </p>
    {% if is_trial and trial_end_date %}
        <div class="highlight-box">
            <p>
                You have a <strong>{{ TRIAL_PERIOD_DAYS }}-day free trial</strong> of our Business plan
                with full access to all features. We'll notify you before it ends.
            </p>
        </div>
    {% endif %}
    <p>To get started, head to your dashboard and create your first product.</p>
    <p style="text-align: center; margin: 32px 0;">
        <a href="{{ app_base_url }}/dashboard" class="button">Go to Dashboard</a>
    </p>
    <p>
        New to SBOMs? Check out our <a href="https://sbomify.com/faq">FAQ</a>
        for answers to common questions about getting set up.
    </p>
    <p>Have questions? Just reply to this email and we'll get back to you.</p>
{% endblock %}
{% block signoff %}
    <p>
        Welcome aboard!
        <br>
        <strong>The sbomify Team</strong>
    </p>
{% endblock %}
