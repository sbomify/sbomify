{% extends "core/dashboard_base.htmx.j2" %}
{% block title %}sbomify Plugins{% endblock %}
{% block dashboard_content %}
    {# Reload page when plugin settings are saved so summary counts update #}
    <script>
        document.body.addEventListener("refreshPluginSettings", function() {
            location.reload();
        });
    </script>
    <div class="space-y-6">
        {# Page Header #}
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
            <div class="flex items-center gap-4">
                <div class="tw-avatar tw-avatar-lg">
                    <i class="fas fa-plug"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-text">Plugins</h1>
                    <p class="text-text-muted text-sm">Manage assessment plugins for your workspace</p>
                </div>
            </div>
            {% if plugin_stats %}
                <div class="flex items-center gap-2">
                    <span class="tw-badge-success text-xs">
                        <i class="fas fa-check-circle mr-1"></i>{{ plugin_stats.enabled }} active
                    </span>
                    <span class="tw-badge-secondary text-xs">{{ plugin_stats.total }} available</span>
                </div>
            {% endif %}
        </div>
        {% if team and team.key %}
            {# Summary Bar — reloads on save to update counts #}
            {% if plugin_stats %}
                <div class="tw-card px-5 py-3">
                    <div class="flex items-center flex-wrap gap-x-6 gap-y-2 text-sm">
                        <div class="flex items-center gap-2">
                            <i class="fas fa-puzzle-piece text-primary"></i>
                            <span class="font-semibold text-text">{{ plugin_stats.total }}</span>
                            <span class="text-text-muted">available</span>
                        </div>
                        <div class="w-px h-4 bg-border"></div>
                        <div class="flex items-center gap-2">
                            <i class="fas fa-check-circle text-success"></i>
                            <span class="font-semibold text-text">{{ plugin_stats.enabled }}</span>
                            <span class="text-text-muted">enabled</span>
                        </div>
                        <div class="w-px h-4 bg-border"></div>
                        {% for category, count in plugin_stats.categories.items %}
                            <div class="flex items-center gap-2">
                                {% if category == "security" %}
                                    <i class="fas fa-shield-alt text-info"></i>
                                {% elif category == "compliance" %}
                                    <i class="fas fa-clipboard-check text-info"></i>
                                {% elif category == "attestation" %}
                                    <i class="fas fa-certificate text-info"></i>
                                {% else %}
                                    <i class="fas fa-plug text-info"></i>
                                {% endif %}
                                <span class="font-semibold text-text">{{ count }}</span>
                                <span class="text-text-muted capitalize">{{ category }}</span>
                            </div>
                            {% if not forloop.last %}<div class="w-px h-4 bg-border"></div>{% endif %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
            {# Plugin Content (loaded via HTMX) #}
            <div id="plugins-page-content"
                 hx-get="{% url 'plugins:team_plugin_settings' team.key %}"
                 hx-trigger="load, refreshPluginSettings from:body"
                 hx-swap="innerHTML">
                {# Skeleton Loading State #}
                <div class="tw-card">
                    <div class="px-6 py-4 border-b border-border">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg bg-border/50 animate-pulse"></div>
                            <div>
                                <div class="h-5 w-24 bg-border/50 rounded animate-pulse"></div>
                                <div class="h-4 w-48 bg-border/30 rounded animate-pulse mt-1"></div>
                            </div>
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="space-y-3">
                            {% for i in "123456" %}
                                <div class="p-4 bg-background/30 rounded-xl border border-border">
                                    <div class="flex items-start gap-4">
                                        <div class="w-10 h-10 rounded-lg bg-border/50 animate-pulse shrink-0"></div>
                                        <div class="flex-1">
                                            <div class="h-4 w-40 bg-border/50 rounded animate-pulse"></div>
                                            <div class="h-3 w-full bg-border/30 rounded animate-pulse mt-2"></div>
                                            <div class="h-3 w-2/3 bg-border/30 rounded animate-pulse mt-1"></div>
                                        </div>
                                        <div class="w-12 h-6 bg-border/50 rounded-full animate-pulse shrink-0"></div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="tw-card p-8 text-center">
                <div class="w-16 h-16 rounded-2xl bg-border/30 flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-building text-2xl text-text-muted"></i>
                </div>
                <h3 class="text-lg font-semibold text-text m-0 mb-1">No workspace selected</h3>
                <p class="text-text-muted text-sm m-0">Select a workspace from the sidebar to manage plugins.</p>
            </div>
        {% endif %}
    </div>
{% endblock dashboard_content %}
