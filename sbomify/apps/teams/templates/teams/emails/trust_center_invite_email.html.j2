{% extends "core/emails/base.html.j2" %}
{% block title %}You have been invited to access {{ team.name }}'s Trust Center{% endblock %}
{% block content %}
    <h1>Trust Center invitation</h1>
    <p>
        {# djlint:off #}
        {% if user.get_full_name %}{{ user.get_full_name }}{% else %}{{ user.email }}{% endif %}
        {# djlint:on #}
        has invited you to access the <strong>{{ team.name }}</strong> Trust Center on sbomify.
    </p>
    <p>
        After accepting, you may be asked to create an account or sign an NDA.
        Once that's done, you'll have access to gated components and documents.
    </p>
    <p style="text-align: center; margin: 32px 0;">
        <a href="{{ base_url }}{% url 'teams:accept_invite' invitation.token %}"
           class="button">Accept Invitation</a>
    </p>
    <p class="text-secondary">This invitation expires on {{ invitation.expires_at|date:"F d, Y" }}.</p>
{% endblock %}
